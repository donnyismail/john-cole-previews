---
title: Cole's Capital Group
pageTitle: Cole's Capital Group | Real Estate Holdings, Albany NY
canonical: /
---
<header class="hero"{% if site.heroImage %} style="--hero-img:url('{{ site.heroImage | imgUrl('coles') }}')"{% endif %}>
  <div class="wrap hero-in">
    <p class="eyebrow rv">Albany · New York's Capital Region</p>
    <h1 class="rv">Building value.<br><em>Creating legacy.</em></h1>
    <p class="rv">A privately held real estate investment and management company acquiring, developing, and stewarding distinctive properties across Upstate New York.</p>
    <div class="cta-row rv">
      <a href="#portfolio" class="btn btn-fill">View Portfolio</a>
      <a href="#contact" class="btn">Speak With Us</a>
    </div>
  </div>
</header>

<section class="stats" style="padding:0">
  <div class="wrap stats-in">
    {% for s in collections.stats %}<div class="stat rv"><b>{{ s.data.value }}</b><span>{{ s.data.label }}</span></div>{% endfor %}
  </div>
</section>

<main id="main">
<section id="about">
  <div class="wrap who">
    <div class="rv">
      <p class="sec-label">Who We Are</p>
      <h2>A steady hand on <em>Capital Region</em> real estate.</h2>
      <p>Cole's Capital Group acquires, improves, and holds quality real estate for the long term. We are not flippers chasing a quick exit, we are owners building durable, income-producing assets and the relationships that sustain them.</p>
      <p>From residential holdings to commercial space and hospitality, our portfolio reflects a disciplined approach: buy well, manage closely, and create lasting value for partners, tenants, and the communities we invest in.</p>
    </div>
    <div class="who-img rv"></div>
  </div>
</section>

<section class="portfolio" id="portfolio">
  <div class="wrap">
    <div class="pf-head rv">
      <div>
        <p class="sec-label">The Portfolio</p>
        <h2>Four classes. One standard.</h2>
      </div>
      <a href="#contact" class="btn">Request the Full Deck</a>
    </div>
    <div class="pf-grid">
      {% for p in collections.portfolio %}
      <div class="pf rv"><div class="bg" style="background-image:url('{{ p.data.image | imgUrl('coles') }}')"></div><div class="cap"><small>{{ p.data.label }}</small><h3>{{ p.data.title }}</h3><p>{{ p.data.blurb }}</p></div></div>
      {% endfor %}
    </div>
  </div>
</section>

<section id="projects">
  <div class="wrap ledger">
    <p class="sec-label">Track Record</p>
    <h2>A history of finishing well.</h2>
    {% for p in collections.projects %}
    <div class="row rv"><span class="yr">{{ p.data.year | yy }}</span><div class="desc"><h3>{{ p.data.title }}</h3><p>{{ p.data.note }}</p></div><span class="val">{{ p.data.category }}</span></div>
    {% endfor %}
  </div>
</section>

<section class="upcoming" id="upcoming">
  <div class="wrap">
    <p class="sec-label rv">In the Pipeline</p>
    <h2 class="rv" style="font-size:clamp(32px,4.2vw,54px);font-weight:400">What we're building next.</h2>
    <div class="up-grid">
      {% for p in collections.pipeline %}
      <div class="up rv"><span class="status{% if p.data.soft %} soft{% endif %}">{{ p.data.status }}</span><h3>{{ p.data.title }}</h3><p class="town">{{ p.data.town }}</p><p>{{ p.data.note }}</p></div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="press" id="press">
  <div class="wrap">
    <p class="sec-label rv">In the News</p>
    <h2 class="rv">As featured in the press.</h2>
    <p class="lede rv">Coverage of our projects and growth across the Capital Region.</p>
    <div class="press-grid">
      {% for p in collections.press %}
      <a class="clip rv" href="{{ p.data.url }}"{% if p.data.url and p.data.url != "#" %} target="_blank" rel="noopener"{% endif %} aria-label="Read the {{ p.data.source }} feature">
        <span class="src">{{ p.data.source }}</span>
        <h3>{{ p.data.title }}</h3>
        <span class="more">Read the feature</span>
      </a>
      {% endfor %}
    </div>
  </div>
</section>

<section class="invite">
  <div class="wrap">
    <h2 class="rv">Let's build something <em>that lasts.</em></h2>
    <p class="rv">Whether you're an investor, a partner, or a prospective tenant, we'd welcome the conversation.</p>
    <a href="#contact" class="btn btn-fill rv">Start the Conversation</a>
  </div>
</section>
</main>
